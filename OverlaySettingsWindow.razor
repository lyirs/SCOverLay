@namespace StarCitizenOverLay
@using Microsoft.AspNetCore.Components.Web

<div class="overlay-window" style="@WindowStyle" @onmousedown="OnFocus">
    <div class="window-head" @onmousedown="OnDragStart" @onmousedown:preventDefault="true">
        <div style="min-width:0;">
            <div class="window-title">设置</div>
            <div class="window-subtitle">本地配置即时生效，API 地址继续由 `.env` 管理。</div>
        </div>
        <button type="button" class="window-close" @onclick="OnClose">×</button>
    </div>

    <div class="window-body ts">
        <div class="window-content">
            <div class="settings-section">
                <div class="settings-section-title">界面显示</div>
                <label class="settings-check">
                    <input type="checkbox" checked="@Settings.ShowSidebarTitlePanel" @onchange="HandleTitlePanelChanged" />
                    <span>标题卡</span>
                </label>
                <label class="settings-check">
                    <input type="checkbox" checked="@Settings.ShowSidebarLogPanel" @onchange="HandleLogPanelChanged" />
                    <span>事件频道</span>
                </label>
                <label class="settings-check">
                    <input type="checkbox" checked="@Settings.ShowMainTerminalPanel" @onchange="HandleMainTerminalChanged" />
                    <span>主终端</span>
                </label>
            </div>

            <div class="settings-section">
                <div class="settings-section-title">搜索偏好</div>
                <div class="settings-radio-group">
                    <label class="settings-radio">
                        <input type="radio" name="default-search-mode" checked="@(Settings.DefaultSearchMode == OverlaySearchModePreference.Items)" @onchange="@(() => OnDefaultSearchModeChanged.InvokeAsync(OverlaySearchModePreference.Items))" />
                        <span>默认进入物品终端</span>
                    </label>
                    <label class="settings-radio">
                        <input type="radio" name="default-search-mode" checked="@(Settings.DefaultSearchMode == OverlaySearchModePreference.Missions)" @onchange="@(() => OnDefaultSearchModeChanged.InvokeAsync(OverlaySearchModePreference.Missions))" />
                        <span>默认进入任务终端</span>
                    </label>
                </div>

                <div class="settings-field">
                    <div class="settings-label">默认物品关键词</div>
                    <input class="search-input settings-input" value="@Settings.DefaultItemQuery" @onchange="HandleDefaultItemQueryChanged" />
                    <div class="settings-note">只影响物品终端的默认输入值；任务终端仍然保持空白待搜。</div>
                </div>
            </div>

            <div class="settings-section">
                <div class="settings-section-title">热键说明</div>
                <div class="settings-hint">@Settings.InteractionToggleHint</div>
                <div class="settings-hint">@Settings.VisibilityToggleHint</div>
                <div class="settings-hint">@Settings.ExitHint</div>
            </div>

            <div class="settings-actions">
                <button type="button" class="mode-btn" @onclick="OnResetToDefaults">恢复默认布局</button>
                <button type="button" class="danger-btn" @onclick="OnExit">退出程序</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string WindowStyle { get; set; } = string.Empty;
    [Parameter] public OverlaySettingsVm Settings { get; set; } = new(true, true, true, true, OverlaySearchModePreference.Items, "P8", string.Empty, string.Empty, string.Empty);
    [Parameter] public EventCallback<MouseEventArgs> OnDragStart { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnFocus { get; set; }
    [Parameter] public EventCallback<bool> OnShowSidebarTitlePanelChanged { get; set; }
    [Parameter] public EventCallback<bool> OnShowSidebarLogPanelChanged { get; set; }
    [Parameter] public EventCallback<bool> OnShowMainTerminalPanelChanged { get; set; }
    [Parameter] public EventCallback<OverlaySearchModePreference> OnDefaultSearchModeChanged { get; set; }
    [Parameter] public EventCallback<string> OnDefaultItemQueryChanged { get; set; }
    [Parameter] public EventCallback OnResetToDefaults { get; set; }
    [Parameter] public EventCallback OnExit { get; set; }

    private Task HandleTitlePanelChanged(ChangeEventArgs args) => OnShowSidebarTitlePanelChanged.InvokeAsync(GetCheckedValue(args));
    private Task HandleLogPanelChanged(ChangeEventArgs args) => OnShowSidebarLogPanelChanged.InvokeAsync(GetCheckedValue(args));
    private Task HandleMainTerminalChanged(ChangeEventArgs args) => OnShowMainTerminalPanelChanged.InvokeAsync(GetCheckedValue(args));
    private Task HandleDefaultItemQueryChanged(ChangeEventArgs args) => OnDefaultItemQueryChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private static bool GetCheckedValue(ChangeEventArgs args)
        => args.Value is bool boolValue && boolValue;
}
