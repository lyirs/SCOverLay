@namespace StarCitizenOverLay

<style>
    .control-console{display:grid;gap:12px}
    .control-console-head{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:8px;align-items:start}
    .control-console-title{color:#6fd0ff;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
    .control-console-mode{margin-top:2px;color:#fff;font-size:17px;font-weight:800}
    .control-console-copy{color:#d8e7f3;font-size:13px;line-height:1.55}
    .control-console-actions{display:flex;justify-content:flex-end}
    .control-console-primary{height:30px;padding:0 14px;border-radius:8px;border:1px solid rgba(44,169,225,.84);background:linear-gradient(180deg,rgba(26,96,132,.96),rgba(16,61,87,.96));color:#fff;font-size:12px;font-weight:700;cursor:pointer}
</style>

<div class="control-console">
    <div class="control-console-head">
        <div>
            <div class="control-console-title">控制台</div>
            <div class="control-console-mode">@ModeTitle</div>
        </div>
        <button type="button" class="control-console-primary" @onclick="OnOpenSettings">设置</button>
    </div>

    <div class="control-console-copy">@Description</div>

    <div class="control-console-actions">
        <button type="button" class="danger-btn" @onclick="OnExit">退出程序</button>
    </div>
</div>

@code {
    [Parameter] public string ModeTitle { get; set; } = "可交互";
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public EventCallback OnOpenSettings { get; set; }
    [Parameter] public EventCallback OnExit { get; set; }
}
