<Window x:Class="StarCitizenOverLay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarCitizenOverLay"
        xmlns:data="clr-namespace:System.Windows.Data;assembly=PresentationFramework"
        xmlns:blazor="http://schemas.microsoft.com/winfx/2006/xaml/presentation/blazor"
        mc:Ignorable="d"
        Title="星际公民 Overlay"
        Icon="Assets/AppIcon.ico"
        Width="1280"
        Height="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Focusable="True"
        FocusManager.FocusedElement="{Binding ElementName=SearchBlazorWebView}"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Window.Background>
        <!-- If the opacity is fully transparent, WPF may treat the window like click-through over WebView content. -->
        <SolidColorBrush Color="#010000"
                         Opacity="0.05" />
    </Window.Background>
    <Window.Resources>
        <Style x:Key="OverlayScrollBarStyle"
               TargetType="ScrollBar">
            <Setter Property="Width"
                    Value="8" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Margin"
                    Value="4,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent">
                            <Border Margin="2,0"
                                    Background="#22162430"
                                    CornerRadius="4" />
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#B32CA9E1"
                                                        CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <CollectionViewSource x:Key="GroupedSearchResultsView"
                              Source="{Binding SearchResults}">
            <CollectionViewSource.GroupDescriptions>
                <data:PropertyGroupDescription PropertyName="CategoryLabel" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>
    <Grid Background="Transparent">
        <Border x:Name="OverlayContentHost"
                Margin="0"
                Padding="0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="0">
            <Grid Margin="24">

                <Grid Width="360"
                      HorizontalAlignment="Left">
                    <StackPanel HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                        <Border Padding="18"
                                Background="#CC09131C"
                                BorderBrush="#FF2CA9E1"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="星际公民 Overlay" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#FFD9E7F3"
                                           FontSize="14"
                                           Text="全屏透明宿主层原型" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,14,0,0"
                                Padding="12"
                                Background="#66314B63"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="#FF8ED0F7"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Text="模式" />
                                <TextBlock x:Name="InteractionModeText"
                                           Margin="0,6,0,0"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="可交互" />
                                <TextBlock x:Name="InteractionDescriptionText"
                                           Margin="0,6,0,0"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           Text="当前是全屏透明宿主层。可交互模式下可以点击面板内容。" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#FF8ED0F7"
                                           FontSize="12"
                                           Text="交互切换：小键盘 1" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#FF8ED0F7"
                                           FontSize="12"
                                           Text="显示隐藏：小键盘 0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Margin="0,0,0,18"
                            Padding="12"
                            Background="#B20A141E"
                            BorderBrush="#553D617B"
                            BorderThickness="1"
                            CornerRadius="12"
                            VerticalAlignment="Bottom">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Foreground="#FF8ED0F7"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Text="事件频道" />
                                <Button x:Name="CombatLogRefreshButton"
                                        DockPanel.Dock="Right"
                                        Width="72"
                                        Height="24"
                                        Padding="6,2"
                                        Background="#FF1776A8"
                                        BorderBrush="#FF2CA9E1"
                                        Click="CombatLogRefreshButton_Click"
                                        Content="刷新"
                                        Foreground="White" />
                            </DockPanel>
                            <TextBlock x:Name="CombatLogStatusText"
                                       Margin="0,6,0,0"
                                       Foreground="#FFD9E7F3"
                                       FontSize="12"
                                       Text="等待读取日志。" />
                            <TextBlock x:Name="CombatLogSummaryText"
                                       Margin="0,3,0,0"
                                       Foreground="#FF8ED0F7"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Text="将自动定位 Star Citizen 安装目录并解析最近战斗、上下线和异常事件。" />
                            <ScrollViewer Margin="0,8,0,0"
                                          Height="244"
                                          VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource OverlayScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <ItemsControl ItemsSource="{Binding CombatLogEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6"
                                                    Padding="8,7"
                                                    Background="#66131D29"
                                                    BorderBrush="#443D617B"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Margin="0,0,8,0"
                                                            Padding="6,2"
                                                            Background="{Binding BadgeBackground}"
                                                            CornerRadius="6"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Foreground="White"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding BadgeText}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Foreground="White"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding Headline}" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   Foreground="#FFD9E7F3"
                                                                   FontSize="11"
                                                                   TextWrapping="Wrap">
                                                            <Run Text="{Binding DetailLine, Mode=OneWay}" />
                                                            <Run Text="  ·  " Foreground="#667F9AB1" />
                                                            <Run Text="{Binding ContextLine, Mode=OneWay}" Foreground="#FF8ED0F7" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Margin="8,0,0,0"
                                                               Foreground="#FF8ED0F7"
                                                               FontSize="10"
                                                               VerticalAlignment="Top"
                                                               Text="{Binding TimeText}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="SearchTerminalHost"
                        Width="1100"
                        Height="760"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="#CC09131C"
                        BorderBrush="#FF2CA9E1"
                        BorderThickness="1"
                        CornerRadius="14">
                    <blazor:BlazorWebView x:Name="SearchBlazorWebView"
                                          HostPage="wwwroot\index.html"
                                          Focusable="True"
                                          Loaded="SearchBlazorWebView_Loaded"
                                          Services="{DynamicResource services}">
                        <blazor:BlazorWebView.RootComponents>
                            <blazor:RootComponent Selector="#app"
                                                  ComponentType="{x:Type local:OverlaySearchApp}" />
                        </blazor:BlazorWebView.RootComponents>
                    </blazor:BlazorWebView>
                </Border>

                <Grid Width="760"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="16"
                            Background="#CC09131C"
                            BorderBrush="#FF2CA9E1"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Foreground="#FF8ED0F7"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Text="物品搜索" />
                            <DockPanel Margin="0,12,0,0">
                                <Button x:Name="SearchButton"
                                        DockPanel.Dock="Right"
                                        Width="112"
                                        Height="40"
                                        Margin="14,0,0,0"
                                        Padding="12,6"
                                        Background="#FF1776A8"
                                        BorderBrush="#FF2CA9E1"
                                        Click="SearchButton_Click"
                                        Content="搜索"
                                        Foreground="White" />
                                <TextBox x:Name="SearchQueryTextBox"
                                         Height="40"
                                         Padding="12,8"
                                         VerticalContentAlignment="Center"
                                         Background="#FF101B26"
                                         BorderBrush="#FF2CA9E1"
                                         Foreground="White"
                                         FontSize="18"
                                         KeyDown="SearchQueryTextBox_KeyDown"
                                         Text="VK-00" />
                            </DockPanel>
                            <TextBlock x:Name="ConfigStatusText"
                                       Margin="0,12,0,0"
                                       Foreground="#FFFFB38A"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                            <TextBlock x:Name="SearchStatusText"
                                       Margin="0,10,0,0"
                                       Foreground="#FFD9E7F3"
                                       Text="就绪" />
                            <TextBlock x:Name="SearchSummaryText"
                                       Margin="0,6,0,0"
                                       Foreground="#FF8ED0F7"
                                       Text="还没有执行搜索。" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,14,0,0"
                          Height="620">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.45*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="12"
                                Background="#B309131C"
                                BorderBrush="#662CA9E1"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ListBox x:Name="SearchResultsListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding Source={StaticResource GroupedSearchResultsView}}"
                                     SelectionChanged="SearchResultsListBox_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource OverlayScrollBarStyle}" />
                                </ListBox.Resources>
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,4,0,10"
                                                           Foreground="#FF8ED0F7"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Text="{Binding Name}" />
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"
                                                Value="0" />
                                        <Setter Property="Margin"
                                                Value="0,0,0,10" />
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch" />
                                        <Setter Property="Background"
                                                Value="Transparent" />
                                        <Setter Property="BorderThickness"
                                                Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="SearchResultCard"
                                                Padding="12"
                                                Background="#4D1A2533"
                                                BorderBrush="#664A87A8"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Border x:Name="SearchResultAccent"
                                                        Width="4"
                                                        HorizontalAlignment="Left"
                                                        Background="Transparent"
                                                        CornerRadius="8,0,0,8" />
                                                <Grid Margin="12,0,0,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding PrimaryName}" />
                                                    <TextBlock x:Name="SearchResultSecondaryText"
                                                               Grid.Row="1"
                                                               Margin="0,6,0,0"
                                                               Foreground="#FFD9E7F3"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding SecondaryInfoLine}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SecondaryInfoLine}"
                                                         Value="">
                                                <Setter TargetName="SearchResultSecondaryText"
                                                        Property="Visibility"
                                                        Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                         Value="True">
                                                <Setter TargetName="SearchResultCard"
                                                        Property="Background"
                                                        Value="#66314B63" />
                                                <Setter TargetName="SearchResultCard"
                                                        Property="BorderBrush"
                                                        Value="#FF2CA9E1" />
                                                <Setter TargetName="SearchResultAccent"
                                                        Property="Background"
                                                        Value="#FF2CA9E1" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="12"
                                Background="#B309131C"
                                BorderBrush="#662CA9E1"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource OverlayScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Foreground="#FF8ED0F7"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Text="详细信息" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,2"
                                                Background="#55314B63"
                                                CornerRadius="8">
                                            <TextBlock x:Name="SelectedDetailVersionText"
                                                       Foreground="#FF8ED0F7"
                                                       FontSize="11"
                                                       Text="等待详情" />
                                        </Border>
                                    </DockPanel>
                                    <Border Margin="0,12,0,0"
                                            Padding="14"
                                            Background="#40131D29"
                                            BorderBrush="#553D617B"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Foreground="#FF8ED0F7"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Text="物品概览" />
                                                <Border DockPanel.Dock="Right"
                                                        Padding="8,2"
                                                        Background="#66314B63"
                                                        CornerRadius="8">
                                                    <TextBlock x:Name="SelectedResultCategoryText"
                                                               Foreground="#FF8ED0F7"
                                                               FontSize="12"
                                                               Text="未选中" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock x:Name="SelectedResultNameText"
                                                       Margin="0,12,0,0"
                                                       Foreground="White"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Text="还没有选中结果" />
                                            <TextBlock x:Name="SelectedResultNameChsText"
                                                       Margin="0,6,0,0"
                                                       Foreground="#FFD9E7F3"
                                                       TextWrapping="Wrap"
                                                       Text="执行搜索后会自动选中第一条结果。" />
                                            <TextBlock x:Name="SelectedDetailStatusText"
                                                       Margin="0,10,0,0"
                                                       Foreground="#FF8ED0F7"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="选择左侧结果后加载详情。" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Margin="0,14,0,0"
                                               Foreground="#FF8ED0F7"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Text="详细字段" />
                                    <Border Margin="0,8,0,0"
                                            Background="#40131D29"
                                            BorderBrush="#553D617B"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <Grid Margin="14,12,14,12">
                                            <ItemsControl ItemsSource="{Binding SelectedDetailSections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,12">
                                                            <TextBlock Foreground="#FF8ED0F7"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Text="{Binding Title}" />
                                                            <ItemsControl Margin="0,8,0,0"
                                                                          ItemsSource="{Binding Items}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,0,0,8">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="92" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Foreground="#FF8ED0F7"
                                                                                       FontSize="12"
                                                                                       Text="{Binding Label}" />
                                                                            <TextBlock Grid.Column="1"
                                                                                       Foreground="White"
                                                                                       FontSize="12"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding Value}" />
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="SelectedDetailFieldsEmptyText"
                                                       Foreground="#FFD9E7F3"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="选择左侧结果后查看详细字段。" />
                                        </Grid>
                                    </Border>

                                    <TextBlock Margin="0,14,0,0"
                                               Foreground="#FF8ED0F7"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Text="获取方式" />
                                    <Border Margin="0,8,0,0"
                                            Background="#40131D29"
                                            BorderBrush="#553D617B"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel Margin="14,12,14,12">
                                            <ItemsControl x:Name="SelectedDetailTagsList"
                                                          ItemsSource="{Binding SelectedDetailTags}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,8,8"
                                                                Padding="8,2"
                                                                Background="#66314B63"
                                                                CornerRadius="8">
                                                            <TextBlock Foreground="#FF8ED0F7"
                                                                       FontSize="12"
                                                                       Text="{Binding}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="SelectedDetailTagsEmptyText"
                                                       Foreground="#FFD9E7F3"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="当前没有特殊获取标签。" />
                                            <TextBlock x:Name="SelectedDetailAccessText"
                                                       Margin="0,10,0,0"
                                                       Foreground="#FFD9E7F3"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="暂无获取提示。" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Margin="0,14,0,0"
                                               Foreground="#FF8ED0F7"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Text="价格信息" />
                                    <Border Margin="0,8,0,0"
                                            Background="#40131D29"
                                            BorderBrush="#553D617B"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel Margin="14,12,14,12">
                                            <TextBlock x:Name="SelectedDetailPriceSummaryText"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="暂无价格信息。" />
                                            <ItemsControl ItemsSource="{Binding SelectedDetailPriceGroups}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,10,0,0"
                                                                Padding="10"
                                                                Background="#331A2533"
                                                                BorderBrush="#333D617B"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock Foreground="White"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding PriceText}" />
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Foreground="#FF8ED0F7"
                                                                               FontSize="12"
                                                                               Text="{Binding VersionText}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Foreground="#FFD9E7F3"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding LocationsText}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="SelectedDetailPriceEmptyText"
                                                       Margin="0,10,0,0"
                                                       Foreground="#FFD9E7F3"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="当前没有可展示的价格分组。" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
