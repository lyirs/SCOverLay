<Window x:Class="StarCitizenOverLay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarCitizenOverLay"
        mc:Ignorable="d"
        Title="SC Overlay Prototype"
        Width="520"
        Height="640"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Grid Background="Transparent">
        <Border Margin="24"
                Padding="18"
                Background="#CC09131C"
                BorderBrush="#FF2CA9E1"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="0,0,0,14"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="OverlayPanel_MouseLeftButtonDown">
                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="Star Citizen Overlay" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#FFD9E7F3"
                                   FontSize="14"
                                   Text="Minimal overlay shell with item search" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,4,0,0"
                        Padding="12"
                        Background="#66314B63"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="#FF8ED0F7"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Text="MODE" />
                        <TextBlock x:Name="InteractionModeText"
                                   Margin="0,6,0,0"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Interactive" />
                        <TextBlock x:Name="InteractionDescriptionText"
                                   Margin="0,6,0,0"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Text="Window accepts mouse input. Drag the title area to move the overlay." />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#FF8ED0F7"
                                   FontSize="12"
                                   Text="Hotkey: Alt + Shift + S" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#4D16222F"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="#FF8ED0F7"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Text="ITEM SEARCH" />
                        <DockPanel Margin="0,10,0,0">
                            <Button x:Name="SearchButton"
                                    DockPanel.Dock="Right"
                                    Width="100"
                                    Height="34"
                                    Margin="12,0,0,0"
                                    Padding="12,6"
                                    Background="#FF1776A8"
                                    BorderBrush="#FF2CA9E1"
                                    Click="SearchButton_Click"
                                    Content="Search"
                                    Foreground="White" />
                            <TextBox x:Name="SearchQueryTextBox"
                                     Height="34"
                                     Padding="10,6"
                                     VerticalContentAlignment="Center"
                                     Background="#FF101B26"
                                     BorderBrush="#FF2CA9E1"
                                     Foreground="White"
                                     KeyDown="SearchQueryTextBox_KeyDown"
                                     Text="VK-00" />
                        </DockPanel>
                        <TextBlock x:Name="ConfigStatusText"
                                   Margin="0,10,0,0"
                                   Foreground="#FFFFB38A"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="SearchStatusText"
                                   Margin="0,8,0,0"
                                   Foreground="#FFD9E7F3"
                                   Text="Ready" />
                        <TextBlock x:Name="SearchSummaryText"
                                   Margin="0,6,0,0"
                                   Foreground="#FF8ED0F7"
                                   Text="No search yet." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="#33121A24"
                        CornerRadius="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            Background="#4D1A2533"
                                            BorderBrush="#664A87A8"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           Text="{Binding Name}" />
                                                <Border Margin="10,0,0,0"
                                                        Padding="8,2"
                                                        Background="#66314B63"
                                                        CornerRadius="8">
                                                    <TextBlock Foreground="#FF8ED0F7"
                                                               FontSize="12"
                                                               Text="{Binding CategoryLabel}" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#FFD9E7F3"
                                                       Text="{Binding NameChsDisplay}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#FF8ED0F7"
                                                       Text="{Binding MetaLine}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
