<Window x:Class="StarCitizenOverLay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarCitizenOverLay"
        mc:Ignorable="d"
        Title="星际公民 Overlay"
        Width="1280"
        Height="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Grid Background="Transparent">
        <Border Margin="0"
                Padding="0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="0">
            <Grid Margin="24">

                <StackPanel Width="360"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                    <Border Padding="18"
                            Background="#CC09131C"
                            BorderBrush="#FF2CA9E1"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="星际公民 Overlay" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FFD9E7F3"
                                       FontSize="14"
                                       Text="全屏透明宿主层原型" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0"
                            Padding="12"
                            Background="#66314B63"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="#FF8ED0F7"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Text="模式" />
                            <TextBlock x:Name="InteractionModeText"
                                       Margin="0,6,0,0"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="可交互" />
                            <TextBlock x:Name="InteractionDescriptionText"
                                       Margin="0,6,0,0"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       Text="当前是全屏透明宿主层。可交互模式下可以点击面板内容。" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#FF8ED0F7"
                                       FontSize="12"
                                       Text="快捷键：Alt + Shift + S" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0"
                            Padding="12"
                            Background="#4D16222F"
                            CornerRadius="10">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Foreground="#FF8ED0F7"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Text="击杀日志" />
                                <Button x:Name="CombatLogRefreshButton"
                                        DockPanel.Dock="Right"
                                        Width="96"
                                        Height="30"
                                        Padding="10,4"
                                        Background="#FF1776A8"
                                        BorderBrush="#FF2CA9E1"
                                        Click="CombatLogRefreshButton_Click"
                                        Content="刷新日志"
                                        Foreground="White" />
                            </DockPanel>
                            <TextBlock x:Name="CombatLogStatusText"
                                       Margin="0,10,0,0"
                                       Foreground="#FFD9E7F3"
                                       Text="等待读取日志。" />
                            <TextBlock x:Name="CombatLogSummaryText"
                                       Margin="0,6,0,0"
                                       Foreground="#FF8ED0F7"
                                       TextWrapping="Wrap"
                                       Text="将自动定位 Star Citizen 安装目录并解析最近击杀事件。" />
                            <ScrollViewer Margin="0,10,0,0"
                                          Height="320"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CombatLogEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="10"
                                                    Background="#4D1A2533"
                                                    BorderBrush="#664A87A8"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <Border Padding="8,2"
                                                                Background="{Binding BadgeBackground}"
                                                                CornerRadius="8">
                                                            <TextBlock Foreground="White"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Text="{Binding BadgeText}" />
                                                        </Border>
                                                        <TextBlock Margin="10,0,0,0"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   Text="{Binding Headline}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Foreground="#FFD9E7F3"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding DetailLine}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Foreground="#FF8ED0F7"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding MetaLine}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Width="760"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="16"
                            Background="#CC09131C"
                            BorderBrush="#FF2CA9E1"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Foreground="#FF8ED0F7"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Text="物品搜索" />
                            <DockPanel Margin="0,12,0,0">
                                <Button x:Name="SearchButton"
                                        DockPanel.Dock="Right"
                                        Width="112"
                                        Height="40"
                                        Margin="14,0,0,0"
                                        Padding="12,6"
                                        Background="#FF1776A8"
                                        BorderBrush="#FF2CA9E1"
                                        Click="SearchButton_Click"
                                        Content="搜索"
                                        Foreground="White" />
                                <TextBox x:Name="SearchQueryTextBox"
                                         Height="40"
                                         Padding="12,8"
                                         VerticalContentAlignment="Center"
                                         Background="#FF101B26"
                                         BorderBrush="#FF2CA9E1"
                                         Foreground="White"
                                         FontSize="18"
                                         KeyDown="SearchQueryTextBox_KeyDown"
                                         Text="VK-00" />
                            </DockPanel>
                            <TextBlock x:Name="ConfigStatusText"
                                       Margin="0,12,0,0"
                                       Foreground="#FFFFB38A"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                            <TextBlock x:Name="SearchStatusText"
                                       Margin="0,10,0,0"
                                       Foreground="#FFD9E7F3"
                                       Text="就绪" />
                            <TextBlock x:Name="SearchSummaryText"
                                       Margin="0,6,0,0"
                                       Foreground="#FF8ED0F7"
                                       Text="还没有执行搜索。" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            Padding="12"
                            Height="620"
                            Background="#B309131C"
                            BorderBrush="#662CA9E1"
                            BorderThickness="1"
                            CornerRadius="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="10"
                                                Background="#4D1A2533"
                                                BorderBrush="#664A87A8"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               Text="{Binding Name}" />
                                                    <Border Margin="10,0,0,0"
                                                            Padding="8,2"
                                                            Background="#66314B63"
                                                            CornerRadius="8">
                                                        <TextBlock Foreground="#FF8ED0F7"
                                                                   FontSize="12"
                                                                   Text="{Binding CategoryLabel}" />
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="#FFD9E7F3"
                                                           Text="{Binding NameChsDisplay}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#FF8ED0F7"
                                                           Text="{Binding MetaLine}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
