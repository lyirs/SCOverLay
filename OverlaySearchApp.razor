@namespace StarCitizenOverLay
@inject OverlaySearchApiService ApiService

<style>
    .terminal-scroll {
        scrollbar-width: thin;
        scrollbar-color: rgba(86, 169, 214, .82) rgba(8, 15, 23, .14);
    }

    .terminal-scroll::-webkit-scrollbar {
        width: 5px;
        height: 5px;
    }

    .terminal-scroll::-webkit-scrollbar-track {
        background: rgba(8, 15, 23, .14);
        border-radius: 999px;
    }

    .terminal-scroll::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, rgba(96, 182, 228, .92), rgba(49, 117, 156, .92));
        border-radius: 999px;
    }

    .terminal-root {
        height: 100%;
        padding: 8px 10px;
        box-sizing: border-box;
        color: #f6fbff;
        font-family: "Segoe UI", "Microsoft YaHei UI", sans-serif;
    }

    .terminal-shell {
        height: 100%;
        display: grid;
        grid-template-rows: auto 1fr;
        gap: 8px;
    }

    .panel {
        border: 1px solid rgba(52, 176, 230, .72);
        border-radius: 12px;
        background: linear-gradient(180deg, rgba(17, 31, 45, .96), rgba(8, 17, 26, .92));
        box-sizing: border-box;
    }

    .search-strip {
        padding: 10px 12px;
    }

    .search-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 88px;
        gap: 10px;
        align-items: center;
    }

    .search-input {
        height: 36px;
        padding: 0 12px;
        border-radius: 9px;
        border: 1px solid rgba(52, 176, 230, .72);
        background: rgba(9, 19, 29, .96);
        color: #f7fbff;
        font-size: 16px;
        outline: none;
    }

    .search-button {
        height: 36px;
        border-radius: 9px;
        border: 1px solid rgba(52, 176, 230, .72);
        background: linear-gradient(180deg, #2287bd, #17678f);
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
    }

    .terminal-main {
        min-height: 0;
        display: grid;
        grid-template-columns: 320px minmax(0, 1fr);
        gap: 8px;
    }

    .results-board {
        min-height: 0;
        overflow: hidden;
        display: grid;
        grid-template-rows: auto 1fr;
    }

    .board-header {
        padding: 9px 10px;
        border-bottom: 1px solid rgba(61, 97, 123, .25);
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: end;
    }

    .board-title,
    .column-title {
        font-size: 14px;
        font-weight: 700;
    }

    .board-count,
    .column-count,
    .item-update {
        color: #79bad8;
        font-size: 11px;
        font-family: "Cascadia Mono", "Consolas", monospace;
    }

    .results-body,
    .column-body,
    .mission-source-list,
    .mission-detail-body {
        min-height: 0;
        overflow: auto;
    }

    .results-body {
        padding: 8px 10px;
    }

    .results-list {
        display: grid;
        gap: 4px;
    }

    .terminal-workspace {
        min-height: 0;
        display: grid;
        grid-template-rows: auto 1fr;
        gap: 8px;
    }

    .item-header {
        padding: 10px 12px;
    }

    .item-title-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: start;
    }

    .item-title {
        font-size: 20px;
        font-weight: 700;
        line-height: 1.06;
        word-break: break-word;
    }

    .item-subtitle {
        margin-top: 4px;
        color: #dcebf7;
        font-size: 12px;
        line-height: 1.45;
        white-space: pre-line;
        word-break: break-word;
    }

    .detail-status {
        margin-top: 8px;
        color: #ffcca8;
        font-size: 11px;
        line-height: 1.4;
    }

    .data-shell {
        min-height: 0;
        padding: 10px;
        overflow: hidden;
    }

    .column-shell {
        min-width: 0;
        min-height: 0;
        max-height: 100%;
        align-self: start;
        border: 1px solid rgba(63, 100, 127, .24);
        border-radius: 8px;
        background: rgba(10, 18, 27, .42);
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        overflow: hidden;
    }

    .column-header {
        padding: 8px 10px;
        border-bottom: 1px solid rgba(63, 100, 127, .24);
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: end;
    }

    .market-row,
    .info-row,
    .stat-row {
        border-top: 1px solid rgba(63, 100, 127, .16);
    }

    .market-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 96px;
        gap: 8px;
        padding: 5px 8px;
        align-items: center;
    }

    .market-primary,
    .market-price,
    .stat-value {
        font-size: 11px;
        color: #fff;
    }

    .market-primary,
    .stat-value {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .market-price,
    .stat-value {
        text-align: right;
        font-family: "Cascadia Mono", "Consolas", "Segoe UI", sans-serif;
    }

    .market-secondary,
    .stat-name,
    .blueprint-subtitle,
    .slot-subtitle,
    .modifier-value,
    .mission-detail-subtitle,
    .mission-empty {
        color: #9fd1ee;
        font-size: 10px;
    }

    .market-secondary {
        margin-top: 1px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .info-row,
    .mission-detail-description {
        padding: 6px 8px;
        color: #fff;
        font-size: 11px;
        line-height: 1.4;
        word-break: break-word;
    }

    .section-row {
        padding: 6px 8px;
        border-top: 1px solid rgba(63, 100, 127, .18);
        background: rgba(12, 23, 34, .88);
        color: #79bad8;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .08em;
    }

    .blueprint-header,
    .mission-detail-head {
        padding: 8px 8px 6px 8px;
        border-bottom: 1px solid rgba(63, 100, 127, .16);
    }

    .blueprint-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: start;
    }

    .blueprint-title,
    .mission-detail-title,
    .slot-title {
        font-size: 12px;
        font-weight: 700;
        line-height: 1.2;
        word-break: break-word;
    }

    .blueprint-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        justify-content: flex-end;
    }

    .stat-row {
        display: grid;
        grid-template-columns: 92px minmax(0, 1fr);
        gap: 8px;
        padding: 5px 8px;
        align-items: center;
    }

    .slot-card {
        border-top: 1px solid rgba(63, 100, 127, .16);
        padding: 8px;
        display: grid;
        gap: 6px;
    }

    .slot-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
    }

    .slot-quality {
        color: #79bad8;
        font-size: 10px;
        font-family: "Cascadia Mono", "Consolas", monospace;
    }

    .slot-slider-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 46px;
        gap: 8px;
        align-items: center;
    }

    .quality-slider {
        width: 100%;
        accent-color: #26b8f0;
    }

    .quality-value {
        height: 22px;
        border-radius: 6px;
        border: 1px solid rgba(76, 123, 153, .28);
        background: rgba(15, 28, 40, .92);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-family: "Cascadia Mono", "Consolas", monospace;
    }

    .modifier-row {
        margin-left: 12px;
        padding: 5px 8px;
        border-left: 1px solid rgba(63, 100, 127, .28);
        display: grid;
        gap: 3px;
    }

    .modifier-name {
        color: #dcebf7;
        font-size: 10px;
        line-height: 1.25;
    }

    .modifier-track {
        height: 4px;
        border-radius: 999px;
        background: rgba(27, 49, 66, .9);
        overflow: hidden;
    }

    .modifier-track-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #22d7a0, #35a7ff);
    }

    .mission-column {
        min-height: 0;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
    }

    .mission-source-button {
        font: inherit;
    }

    .mission-detail-box {
        min-height: 0;
        display: grid;
        grid-template-rows: auto auto minmax(0, 1fr);
    }
</style>

<div class="terminal-root">
    <div class="terminal-shell">
        <section class="panel search-strip">
            <div class="search-grid">
                <input class="search-input"
                       @bind="_query"
                       @onkeydown="HandleSearchInputKeyDown"
                       placeholder="搜索物品、商品、矿物，例如：VK-00 / Gold / 紫纳水晶"
                       disabled="@(!ApiService.HasConfiguration || _isSearching)" />
                <button type="button" class="search-button" @onclick="SearchAsync" disabled="@(!ApiService.HasConfiguration || _isSearching)">
                    @(_isSearching ? "搜索中" : "搜索")
                </button>
            </div>
        </section>

        <div class="terminal-main">
            <section class="panel results-board">
                <div class="board-header">
                    <div class="board-title">候选列表</div>
                    <div class="board-count">@GetCompactResultCount()</div>
                </div>

                <div class="results-body terminal-scroll">
                    @if (_results.Count == 0)
                    {
                        <div class="info-row" style="border-top:none;">@GetEmptyText()</div>
                    }
                    else
                    {
                        <div class="results-list">
                            @foreach (var item in _results)
                            {
                                <button type="button" @key="@($"{item.CategoryKey}:{item.Id}")" @onclick="@(() => SelectItemAsync(item))" style="@GetItemStyle(item)">
                                    <div style="display:grid;grid-template-columns:minmax(0,1fr) auto;gap:8px;align-items:center;">
                                        <div style="min-width:0;font-size:13px;font-weight:700;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@GetPrimaryName(item)</div>
                                        <div style="display:flex;gap:4px;align-items:center;justify-content:flex-end;">
                                            @foreach (var tag in BuildResultTags(item))
                                            {
                                                <span style="@tag.Style">@tag.Text</span>
                                            }
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            </section>

            <div class="terminal-workspace">
                <section class="panel item-header">
                    <div class="item-title-row">
                        <div style="min-width:0;">
                            <div class="item-title">@_detailTitle</div>
                            @if (!string.IsNullOrWhiteSpace(_detailSubtitle))
                            {
                                <div class="item-subtitle">@_detailSubtitle</div>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_detailUpdatedAt))
                        {
                            <div class="item-update">@_detailUpdatedAt</div>
                        }
                    </div>
                    @if (ShouldShowDetailStatus())
                    {
                        <div class="detail-status">@_detailStatus</div>
                    }
                </section>

                <section class="panel data-shell">
                    @if (GetVisibleColumnCount() == 0)
                    {
                        <div class="mission-empty">当前条目没有可显示的终端数据。</div>
                    }
                    else
                    {
                        <div style="@BuildDataColumnsStyle()">
                            @if (HasBuyColumn())
                            {
                                <div class="column-shell">
                                    <div class="column-header">
                                        <div class="column-title">买入</div>
                                        <div class="column-count">@GetBuyRows().Count.ToString("00")</div>
                                    </div>
                                    <div class="column-body terminal-scroll">
                                        @foreach (var row in GetBuyRows())
                                        {
                                            <div class="market-row" @key="row.Key">
                                                <div style="min-width:0;">
                                                    <div class="market-primary">@BuildPriceRowDisplay(row)</div>
                                                    @if (!string.IsNullOrWhiteSpace(row.Detail))
                                                    {
                                                        <div class="market-secondary">@row.Detail</div>
                                                    }
                                                </div>
                                                <div class="market-price">@row.PriceText</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (HasSellColumn())
                            {
                                <div class="column-shell">
                                    <div class="column-header">
                                        <div class="column-title">卖出</div>
                                        <div class="column-count">@GetSellRows().Count.ToString("00")</div>
                                    </div>
                                    <div class="column-body terminal-scroll">
                                        @foreach (var row in GetSellRows())
                                        {
                                            <div class="market-row" @key="row.Key">
                                                <div style="min-width:0;">
                                                    <div class="market-primary">@BuildPriceRowDisplay(row)</div>
                                                    @if (!string.IsNullOrWhiteSpace(row.Detail))
                                                    {
                                                        <div class="market-secondary">@row.Detail</div>
                                                    }
                                                </div>
                                                <div class="market-price">@row.PriceText</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (HasAccessColumn())
                            {
                                <div class="column-shell">
                                    <div class="column-header">
                                        <div class="column-title">获取途径</div>
                                        <div class="column-count">@_accessRows.Count.ToString("00")</div>
                                    </div>
                                    <div class="column-body terminal-scroll">
                                        @foreach (var row in _accessRows)
                                        {
                                            <div class="info-row" @key="row">@row</div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (HasBlueprintColumn())
                            {
                                <div class="column-shell">
                                    <div class="column-header">
                                        <div class="column-title">蓝图</div>
                                    </div>
                                    <div class="column-body terminal-scroll">
                                        @if (_blueprintHeader is not null)
                                        {
                                            <div class="blueprint-header">
                                                <div class="blueprint-head">
                                                    <div style="min-width:0;">
                                                        <div class="blueprint-title">@_blueprintHeader.Title</div>
                                                        @if (!string.IsNullOrWhiteSpace(_blueprintHeader.Subtitle))
                                                        {
                                                            <div class="blueprint-subtitle">@_blueprintHeader.Subtitle</div>
                                                        }
                                                    </div>
                                                    @if (_blueprintHeader.Tags.Count > 0)
                                                    {
                                                        <div class="blueprint-tags">
                                                            @foreach (var tag in _blueprintHeader.Tags)
                                                            {
                                                                <span style="@tag.Style">@tag.Text</span>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }

                                        @if (_blueprintMaterials.Count > 0)
                                        {
                                            <div class="section-row">材料</div>
                                            @foreach (var row in _blueprintMaterials)
                                            {
                                                <div class="info-row" @key="row.Key">@row.Text</div>
                                            }
                                        }

                                        @if (GetBlueprintStatRows().Count > 0)
                                        {
                                            <div class="section-row">基础属性</div>
                                            @foreach (var row in GetBlueprintStatRows())
                                            {
                                                <div class="stat-row" @key="row.Key">
                                                    <div class="stat-name">@row.Name</div>
                                                    <div class="stat-value">@row.ValueText</div>
                                                </div>
                                            }
                                        }

                                        @if (_blueprintModifierSlots.Count > 0)
                                        {
                                            <div class="section-row">可调词条</div>
                                            @foreach (var slot in _blueprintModifierSlots)
                                            {
                                                <div class="slot-card" @key="slot.Key">
                                                    <div class="slot-head">
                                                        <div style="min-width:0;">
                                                            <div class="slot-title">@slot.Title</div>
                                                            @if (!string.IsNullOrWhiteSpace(BuildSlotSubtitle(slot)))
                                                            {
                                                                <div class="slot-subtitle">@BuildSlotSubtitle(slot)</div>
                                                            }
                                                        </div>
                                                        <div class="slot-quality">质 @slot.CurrentQuality</div>
                                                    </div>

                                                    <div class="slot-slider-row">
                                                        <input class="quality-slider"
                                                               type="range"
                                                               min="@slot.MinQuality"
                                                               max="1000"
                                                               step="1"
                                                               value="@slot.CurrentQuality"
                                                               @oninput="args => OnBlueprintQualityChanged(slot.Key, args)" />
                                                        <div class="quality-value">@slot.CurrentQuality</div>
                                                    </div>

                                                    @foreach (var modifier in slot.Modifiers)
                                                    {
                                                        <div class="modifier-row" @key="modifier.Key">
                                                            <div class="modifier-name">• @modifier.DisplayName</div>
                                                            <div class="modifier-track">
                                                                <div class="modifier-track-fill" style="@BuildModifierTrackStyle(slot)"></div>
                                                            </div>
                                                            <div class="modifier-value">@BuildModifierPreviewText(slot, modifier)</div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }

                            @if (HasMissionColumn())
                            {
                                <div class="column-shell">
                                    <div class="column-header">
                                        <div class="column-title">任务来源</div>
                                        <div class="column-count">@_missionSources.Count.ToString("00")</div>
                                    </div>

                                    <div class="mission-column">
                                        @if (_missionSources.Count > 0)
                                        {
                                            <div class="mission-source-list terminal-scroll">
                                                @foreach (var source in _missionSources)
                                                {
                                                    <button type="button"
                                                            class="mission-source-button"
                                                            @onclick="@(() => LoadMissionDetailAsync(source))"
                                                            style="@BuildMissionSourceButtonStyle(IsMissionSourceSelected(source))"
                                                            @key="source.Key">
                                                        <div style="font-size:11px;font-weight:700;line-height:1.3;word-break:break-word;">@source.Title</div>
                                                        @if (!string.IsNullOrWhiteSpace(source.SecondaryText))
                                                        {
                                                            <div class="market-secondary" style="margin-top:2px;white-space:normal;">@source.SecondaryText</div>
                                                        }
                                                    </button>
                                                }
                                            </div>
                                        }

                                        <div class="mission-detail-box">
                                            @if (ShouldShowMissionDetailContent())
                                            {
                                                <div class="mission-detail-head">
                                                    <div class="mission-detail-title">@_missionDetailTitle</div>
                                                    @if (!string.IsNullOrWhiteSpace(_missionDetailSubtitle))
                                                    {
                                                        <div class="mission-detail-subtitle">@_missionDetailSubtitle</div>
                                                    }
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(_missionDetailDescription))
                                                {
                                                    <div class="mission-detail-description">@_missionDetailDescription</div>
                                                }

                                                <div class="mission-detail-body terminal-scroll">
                                                    @if (!string.IsNullOrWhiteSpace(_missionDetailStatus))
                                                    {
                                                        <div class="mission-empty">@_missionDetailStatus</div>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var row in _missionDetailRows)
                                                        {
                                                            if (row.Kind == MissionRowKind.Section)
                                                            {
                                                                <div class="section-row" @key="row.Key">@row.Text</div>
                                                            }
                                                            else
                                                            {
                                                                <div class="info-row" @key="row.Key">
                                                                    <div>@row.Text</div>
                                                                    @if (!string.IsNullOrWhiteSpace(row.SecondaryText))
                                                                    {
                                                                        <div class="market-secondary" style="margin-top:2px;white-space:normal;">@row.SecondaryText</div>
                                                                    }
                                                                </div>
                                                            }
                                                        }
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="mission-empty">@GetMissionDetailPlaceholder()</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (HasMiningColumn())
                            {
                                <div class="column-shell">
                                    <div class="column-header">
                                        <div class="column-title">矿物分布</div>
                                        <div class="column-count">@_miningRows.Count.ToString("00")</div>
                                    </div>
                                    <div class="column-body terminal-scroll">
                                        @foreach (var row in _miningRows)
                                        {
                                            <div class="info-row" @key="row">@row</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </section>
            </div>
        </div>
    </div>
</div>
